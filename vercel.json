{
  "version": 2,
  "functions": {
    "backend/main.py": {
      "runtime": "python3.10"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/main.py" },
    { "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|ico|svg|webp))", "dest": "frontend/$1" },
    { "src": "/", "dest": "frontend/index.html" },
    { "src": "/(.*)", "dest": "frontend/index.html" }
  ]
}